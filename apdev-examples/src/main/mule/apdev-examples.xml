	<http:listener-config name="HTTP_Listener_config" doc:name="HTTP Listener config" doc:id="0ce0398b-ebfd-4ee4-b33b-aebb4bf6bf21" >
		<http:listener-connection host="0.0.0.0" port="8081" />
	</http:listener-config>
	<flow name="helloFlow" doc:id="d27cd4ff-d058-4291-8dc2-1a743e9a46cf" >
		<http:listener doc:name="Listener" doc:id="d0d9d8f6-3353-49bc-9cf8-1b1367655c58" config-ref="HTTP_Listener_config" path="/hello">
			<repeatable-in-memory-stream />
		</http:listener>
		<set-payload value="Hello" doc:name="Hello" doc:id="c13a2038-e222-4fb7-a3d8-ba463c10ade5" />
		<logger level="INFO" doc:name="Logger" doc:id="7c7818a1-5277-44f3-a506-7a09d02f16cc" />
	</flow>
</mule>
